# Glas — environment variables
# ---------------------------------------------------------------------------
# This file documents the variables the app needs. It is SAFE to commit.
# Never put real secret values in this file or anywhere in the repo.
#
# In production these are set in the Cloudflare Pages dashboard under:
#   Workers & Pages > (your project) > Settings > Variables and Secrets
# For local development with `wrangler pages dev`, copy this file to `.dev.vars`
# (which is gitignored) and fill in your real key there.

# REQUIRED — your ElevenLabs API key. Stored ONLY as an encrypted secret in
# Cloudflare Pages; it is never exposed to the browser.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OPTIONAL — override the Scribe model. Defaults to "scribe_v2".
# Note: "scribe_v1" is deprecated and is being removed by ElevenLabs on
# 2026-07-09, so leave this unset unless ElevenLabs tells you otherwise.
# ELEVENLABS_MODEL_ID=scribe_v2

# OPTIONAL — override the forced transcription language (ISO-639-1/3).
# Defaults to "hr" (Croatian).
# ELEVENLABS_LANGUAGE_CODE=hr

# OPTIONAL — shared access code. If set, the /api/transcribe endpoint requires
# callers to send this value (the app prompts friends for it once and stores it
# in their browser). Leave unset to keep the endpoint open. Set it as a Secret
# in the dashboard to lock the app down to people you share the code with.
# APP_PASSCODE=choose-a-shared-code

# OPTIONAL — ElevenLabs API host. Defaults to the global host
# (https://api.elevenlabs.io). If your ElevenLabs account uses EU data
# residency, set this to the EU host (an EU key ONLY works against the EU host):
# ELEVENLABS_BASE_URL=https://api.eu.residency.elevenlabs.io
